{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jest",           // si tu utilises Jest
      "node"            // pour Node globals comme process, Buffer
      // "vitest/globals" // décommente si tu passes à Vitest
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}